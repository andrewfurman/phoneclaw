{
  "name": "phoneclaw",
  "version": "0.1.0",
  "private": true,
  "description": "Claw Phone: a Twilio-to-ElevenLabs voice bridge with a future Claude Code command bridge.",
  "scripts": {
    "start": "node --env-file-if-exists=.env fastify-app/server.mjs",
    "check": "node --check fastify-app/server.mjs && node --check fastify-app/cli-tools.mjs && node --check fastify-app/github-gh-tools.mjs && node --check fastify-app/claude-code-tools.mjs && node --check fastify-app/conversation-history.mjs && node --check fastify-app/economist-browser-fetcher.mjs && node --check fastify-app/miniflux-tools.mjs && node --check setup-and-testing-scripts/auth-economist-browser.mjs && node --check setup-and-testing-scripts/test-elevenlabs-rss-conversation.mjs && node --check setup-and-testing-scripts/test-elevenlabs-economist-audio.mjs && node --check setup-and-testing-scripts/test-economist-full-text.mjs && node --check setup-and-testing-scripts/test-himalaya-email-send-validation.mjs && node --check setup-and-testing-scripts/test-himalaya-email-forward-validation.mjs && node --check setup-and-testing-scripts/test-himalaya-email-draft-tools.mjs && node --check setup-and-testing-scripts/test-himalaya-email-archive-validation.mjs && node --check setup-and-testing-scripts/test-elevenlabs-email-archive-audio.mjs && node --check setup-and-testing-scripts/test-elevenlabs-email-forward.mjs && node --check setup-and-testing-scripts/test-elevenlabs-email-drafts.mjs && node --check setup-and-testing-scripts/test-elevenlabs-email-send.mjs && node --check setup-and-testing-scripts/build-visualizer-worker-assets.mjs && node --check setup-and-testing-scripts/test-visualizer.mjs && node --check setup-and-testing-scripts/test-elevenlabs-visualizer-demo.mjs && node --check setup-and-testing-scripts/capture-visualizer-screenshots.mjs",
    "tunnel": "npx --yes localtunnel --port 8000 --local-host 127.0.0.1",
    "twilio": "twilio",
    "elevenlabs:audio:check": "node --env-file-if-exists=.env setup-and-testing-scripts/check-elevenlabs-audio-format.mjs",
    "elevenlabs:audio:fix": "node --env-file-if-exists=.env setup-and-testing-scripts/check-elevenlabs-audio-format.mjs --fix",
    "audio:diagnose": "node --env-file-if-exists=.env setup-and-testing-scripts/diagnose-audio-path.mjs",
    "elevenlabs:agent:export": "node --env-file-if-exists=.env setup-and-testing-scripts/export-elevenlabs-agent-config.mjs",
    "elevenlabs:github:configure": "node --env-file-if-exists=.env setup-and-testing-scripts/configure-elevenlabs-github-tools.mjs",
    "elevenlabs:tools:configure": "node --env-file-if-exists=.env setup-and-testing-scripts/configure-elevenlabs-github-tools.mjs",
    "elevenlabs:github:test": "node --env-file-if-exists=.env setup-and-testing-scripts/test-elevenlabs-github-tools.mjs",
    "elevenlabs:github:files:test": "node --env-file-if-exists=.env setup-and-testing-scripts/test-elevenlabs-github-files.mjs",
    "elevenlabs:github:audio:test": "node --env-file-if-exists=.env setup-and-testing-scripts/test-elevenlabs-github-audio.mjs",
    "elevenlabs:email:audio:test": "node --env-file-if-exists=.env setup-and-testing-scripts/test-elevenlabs-email-audio.mjs",
    "elevenlabs:email-forward:test": "node --env-file-if-exists=.env setup-and-testing-scripts/test-elevenlabs-email-forward.mjs",
    "elevenlabs:email-drafts:test": "node --env-file-if-exists=.env setup-and-testing-scripts/test-elevenlabs-email-drafts.mjs",
    "elevenlabs:email-send:test": "node --env-file-if-exists=.env setup-and-testing-scripts/test-elevenlabs-email-send.mjs",
    "elevenlabs:email-archive:audio:test": "node --env-file-if-exists=.env setup-and-testing-scripts/test-elevenlabs-email-archive-audio.mjs",
    "elevenlabs:logging:audio:test": "node --env-file-if-exists=.env setup-and-testing-scripts/test-elevenlabs-logging-audio.mjs",
    "elevenlabs:rss:conversation:test": "node --env-file-if-exists=.env setup-and-testing-scripts/test-elevenlabs-rss-conversation.mjs",
    "elevenlabs:economist:audio:test": "node --env-file-if-exists=.env setup-and-testing-scripts/test-elevenlabs-economist-audio.mjs",
    "himalaya:email-send:validation:test": "node --env-file-if-exists=.env setup-and-testing-scripts/test-himalaya-email-send-validation.mjs",
    "himalaya:email-forward:validation:test": "node --env-file-if-exists=.env setup-and-testing-scripts/test-himalaya-email-forward-validation.mjs",
    "himalaya:email-drafts:test": "node --env-file-if-exists=.env setup-and-testing-scripts/test-himalaya-email-draft-tools.mjs",
    "himalaya:email-archive:validation:test": "node --env-file-if-exists=.env setup-and-testing-scripts/test-himalaya-email-archive-validation.mjs",
    "economist:auth:browser": "node --env-file-if-exists=.env setup-and-testing-scripts/auth-economist-browser.mjs",
    "economist:full-text:test": "node --env-file-if-exists=.env setup-and-testing-scripts/test-economist-full-text.mjs",
    "miniflux:economist:setup": "node --env-file-if-exists=.env setup-and-testing-scripts/setup-miniflux-economist-feeds.mjs",
    "neon:setup": "node --env-file-if-exists=.env setup-and-testing-scripts/setup-neon-conversation-db.mjs",
    "conversations:archive": "node --env-file-if-exists=.env setup-and-testing-scripts/archive-elevenlabs-conversations.mjs",
    "visualizer:build": "vite build --config visualizer-app/vite.config.mjs && node setup-and-testing-scripts/build-visualizer-worker-assets.mjs",
    "visualizer:test": "node --env-file-if-exists=.env setup-and-testing-scripts/test-visualizer.mjs",
    "visualizer:demo-test": "node --env-file-if-exists=.env setup-and-testing-scripts/test-elevenlabs-visualizer-demo.mjs",
    "visualizer:screenshots": "node --env-file-if-exists=.env setup-and-testing-scripts/capture-visualizer-screenshots.mjs",
    "worker:check": "node --check cloudflare-worker/twilio-elevenlabs-worker.mjs",
    "worker:deploy": "wrangler deploy --config wrangler.toml"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "fastify": "^5.8.5",
    "html-to-text": "^10.0.0",
    "pg": "^8.22.0",
    "playwright": "^1.61.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "vite": "^8.0.16",
    "wrangler": "^4.102.0"
  }
}
