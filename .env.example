PORT=8000
HOST=127.0.0.1

# ElevenLabs
ELEVENLABS_API_KEY=replace-with-elevenlabs-api-key
ELEVENLABS_AGENT_ID=replace-with-elevenlabs-agent-id
ELEVENLABS_API_BASE=https://api.elevenlabs.io
ELEVENLABS_TELEPHONY_AUDIO_FORMAT=ulaw_8000

# Optional, used only for display/logging and outbound Twilio work later.
TWILIO_PHONE_NUMBER=+15555550123
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
ENFORCE_TWILIO_SIGNATURE=false
TWILIO_WEBHOOK_TOKEN=replace-with-random-webhook-token
ALLOWED_CALLER_NUMBERS=+15555550123
OUTSIDE_COVERAGE_MESSAGE=Thanks for calling Andrew's assistance line. Sorry we haven't set up outside coverage yet.
TWILIO_EVENT_LOG_TTL_SECONDS=604800
AUTO_ARCHIVE_CONVERSATIONS_ON_CALL_END=true
AUTO_ARCHIVE_CONVERSATION_LIMIT=5

# Future Claude Code bridge. Keep this secret long and random.
COMMAND_BRIDGE_TOKEN=replace-with-long-random-token

# ElevenLabs webhook tool auth. Falls back to COMMAND_BRIDGE_TOKEN if unset.
WEB_SEARCH_TOKEN=replace-with-long-random-token
WEB_SEARCH_PROVIDER=auto
# Set TAVILY_API_KEY to use Tavily; without it, search falls back to DuckDuckGo.
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=fast

# Private CLI bridge. Cloudflare Workers cannot execute local CLI binaries, so the
# public Worker should proxy CLI tool calls to a Fastify bridge on a VM/container.
# Set CLI_BRIDGE_URL on the Worker only. Set CLI_BRIDGE_TOKEN on both Worker and bridge.
CLI_BRIDGE_URL=https://your-private-cli-bridge.example.com
CLI_BRIDGE_TOKEN=replace-with-different-long-random-token
HIMALAYA_BIN=himalaya
HIMALAYA_SEND_TIMEOUT_MS=8000
OTTER_BIN=otter
GH_BIN=gh
HIMALAYA_ARCHIVE_FOLDER="[Gmail]/All Mail"
HIMALAYA_DRAFTS_FOLDER="[Gmail]/Drafts"
MINIFLUX_BASE_URL=http://127.0.0.1:8080
MINIFLUX_API_TOKEN=replace-with-miniflux-api-token

# Generic configured RSS feeds. Use RSS_FEEDS_CONFIG_PATH for private feed URLs
# with tokens so they stay out of process listings, shell history, and Git.
# Example config file:
# {"feeds":[{"id":"economist","title":"The Economist","url":"https://example.com/rss.xml?token=replace-with-token","private":true,"cache_seconds":900}]}
RSS_FEEDS_CONFIG_PATH=/etc/phoneclaw/rss-feeds.json
# Or inline JSON for local testing only:
# RSS_FEEDS_JSON=[{"id":"example","title":"Example Feed","url":"https://example.com/feed.xml","private":false}]
RSS_FEEDS_CACHE_SECONDS=900
RSS_FEEDS_TIMEOUT_MS=12000

# Legacy Economist-specific RSS/Miniflux settings. Prefer RSS_FEEDS_CONFIG_PATH
# for new private/public feed integrations.
MINIFLUX_ECONOMIST_CATEGORY_TITLE=Economist
# Optional, avoids category lookup by title.
# MINIFLUX_ECONOMIST_CATEGORY_ID=123
# Optional secure full-text feed exposed by the private bridge. Store the real token only in host env.
ECONOMIST_RSS_BRIDGE_URL=https://cli-bridge.aifurman.com/rss/economist/latest.atom
ECONOMIST_RSS_BRIDGE_TOKEN=replace-with-rss-bridge-token
# EC2-only proxy settings for exposing the RSS-Bridge latest feed through Fastify.
ECONOMIST_PUBLIC_RSS_TOKEN=replace-with-public-rss-token
ECONOMIST_RSS_BRIDGE_BASE_URL=http://127.0.0.1:3000/
ECONOMIST_PUBLIC_RSS_MAX_ENTRIES=10
ECONOMIST_PUBLIC_RSS_CACHE_SECONDS=900
ECONOMIST_BROWSER_FETCH_ENABLED=false
ECONOMIST_BROWSER_STORAGE_STATE=/var/lib/phoneclaw/economist-browser-state.json
ECONOMIST_BROWSER_USER_DATA_DIR=/var/lib/phoneclaw/economist-browser-profile
ECONOMIST_BROWSER_HEADLESS=true
CLAUDE_BIN=claude
CLAUDE_CODE_JOB_DIR=/var/lib/phoneclaw/claude-jobs
CLAUDE_CODE_ALLOWED_DIRS=/opt/phoneclaw
CLAUDE_CODE_DANGEROUSLY_SKIP_PERMISSIONS=false
AWS_PROFILE=phoneclaw-personal
# Optional. If unset, Claude Code uses its configured login/token state.
# ANTHROPIC_API_KEY=replace-with-anthropic-api-key

# Conversation memory archive. Use `npm run neon:setup` with NEON_API_KEY in the
# shell to create/reuse a Neon project, then set the returned URI here.
CONVERSATION_DATABASE_URL=
NEON_API_KEY=
NEON_PROJECT_NAME=phoneclaw-conversations
NEON_REGION_ID=aws-us-east-1

# GitHub tools run through the authenticated GitHub CLI on the private bridge.
# Authenticate the bridge service user with:
#   gh auth login --hostname github.com --scopes repo,read:org,workflow
# Optional. If unset, the app resolves the username from the gh-authenticated account.
GITHUB_USERNAME=your-github-login

# Leave unset until the EC2 Claude bridge exists.
# CLAUDE_BRIDGE_URL=https://your-ec2-bridge.example.com/commands
# CLAUDE_BRIDGE_TOKEN=replace-with-ec2-bridge-token
