PORT=8000
HOST=127.0.0.1

# ElevenLabs
ELEVENLABS_API_KEY=replace-with-elevenlabs-api-key
ELEVENLABS_AGENT_ID=replace-with-elevenlabs-agent-id
ELEVENLABS_API_BASE=https://api.elevenlabs.io
ELEVENLABS_TELEPHONY_AUDIO_FORMAT=ulaw_8000

# Optional, used only for display/logging and outbound Twilio work later.
TWILIO_PHONE_NUMBER=+15555550123
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
ENFORCE_TWILIO_SIGNATURE=false
TWILIO_WEBHOOK_TOKEN=replace-with-random-webhook-token
ALLOWED_CALLER_NUMBERS=+15555550123
OUTSIDE_COVERAGE_MESSAGE=Thanks for calling Andrew's assistance line. Sorry we haven't set up outside coverage yet.

# Future Claude Code bridge. Keep this secret long and random.
COMMAND_BRIDGE_TOKEN=replace-with-long-random-token

# ElevenLabs webhook tool auth. Falls back to COMMAND_BRIDGE_TOKEN if unset.
WEB_SEARCH_TOKEN=replace-with-long-random-token

# Read-only GitHub API access for issue/PR summaries, repository trees, and file contents.
# For private repos, the token needs access to the selected repos/org plus read access to
# repository metadata, contents, issues, and pull requests as needed.
GITHUB_READ_TOKEN=replace-with-read-only-github-token
# Optional. If unset, the app resolves the username from GITHUB_READ_TOKEN.
# GITHUB_USERNAME=your-github-login

# Leave unset until the EC2 Claude bridge exists.
# CLAUDE_BRIDGE_URL=https://your-ec2-bridge.example.com/commands
# CLAUDE_BRIDGE_TOKEN=replace-with-ec2-bridge-token
